---
import Icon from "./Icon.astro";
import { cityBenefits, whatsappUrl } from "../data/site";
const wa = whatsappUrl("Olá! Represento um município e quero conhecer a parceria pública da MicroSertão.");
const campaigns = ["Vacinação", "Matrícula escolar", "Cursos profissionalizantes", "Vagas de emprego", "Campanhas de saúde", "Eventos culturais"];
---

<section id="prefeituras" class="relative py-20 md:py-28 bg-navy-700 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-grid opacity-30"></div>
  <div class="absolute -top-20 -right-20 -z-10 w-96 h-96 stripes opacity-[0.06] rotate-12"></div>

  <div class="container-x grid lg:grid-cols-2 gap-12 items-center">
    <div class="reveal">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs text-white/80">
        <Icon name="megaphone" class="w-4 h-4 text-sun-400" /> Para municípios
      </span>
      <h2 class="mt-5 font-display font-bold text-white text-3xl sm:text-4xl tracking-tight text-balance">
        Comunicação pública direcionada, com economia real.
      </h2>
      <p class="mt-4 text-white/70 text-lg">
        Através do comércio local, o município alcança o cidadão certo, na hora certa —
        sem depender de publicidade cara em plataformas estrangeiras.
      </p>

      <div class="mt-7 flex flex-wrap gap-2">
        {campaigns.map((c) => (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-white/8 border border-white/10 px-3 py-1.5 text-sm text-white/85">
            <span class="w-1.5 h-1.5 rounded-full bg-sun-400"></span>{c}
          </span>
        ))}
      </div>

      <a href={wa} target="_blank" rel="noopener" class="btn mt-8 bg-sun-400 text-navy-700 hover:bg-sun-400/90 font-semibold">
        Falar sobre parceria pública
        <Icon name="arrow" class="w-4 h-4" />
      </a>
    </div>

    <ul class="grid sm:grid-cols-2 gap-3 reveal">
      {cityBenefits.map((b) => (
        <li class="flex items-start gap-3 rounded-2xl bg-white/5 border border-white/10 p-4">
          <span class="grid place-items-center shrink-0 w-7 h-7 rounded-lg bg-sun-400/20 text-sun-400">
            <Icon name="check" class="w-4 h-4" />
          </span>
          <span class="text-sm text-white/85 leading-relaxed">{b}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
