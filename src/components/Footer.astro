---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { company, navLinks, footerContacts, footerLegal, whatsappUrl } from "../data/site";
const year = new Date().getFullYear();
const wa = whatsappUrl("Olá! Quero conhecer a MicroSertão.");
const contactHref = (c: { type: string; value: string }) =>
  c.type === "whatsapp" ? wa : c.type === "mail" ? `mailto:${company.email}` : undefined;
---

<footer class="bg-ink-900 border-t border-white/8">
  <div class="container-x py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- Coluna 1: marca + começar -->
      <div>
        <Logo />
        <p class="mt-4 text-sm text-paragraph max-w-xs">{company.slogan}</p>
        <div class="mt-6 space-y-2">
          <a href={wa} target="_blank" rel="noopener" class="flex items-center gap-2.5 rounded-lg bg-white/5 border border-white/10 hover:border-brand-500 px-4 py-2.5 transition-colors w-fit">
            <Icon name="whatsapp" class="w-5 h-5 text-brand-500" />
            <span class="text-sm font-medium text-white">{company.whatsappLabel}</span>
          </a>
        </div>
      </div>

      <!-- Coluna 2: navegação + transparência -->
      <div>
        <p class="font-display font-bold text-white text-sm">Navegação</p>
        <ul class="mt-4 space-y-2.5">
          {navLinks.map((l) => (
            <li><a href={l.href} class="text-sm text-paragraph hover:text-white transition-colors">{l.label}</a></li>
          ))}
        </ul>
        <p class="mt-6 font-display font-bold text-white text-sm">Transparência</p>
        <ul class="mt-4 space-y-2.5">
          {footerLegal.map((l) => (
            <li><a href={l.href} class="text-sm text-paragraph hover:text-white transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Coluna 3: contato -->
      <div>
        <p class="font-display font-bold text-white text-sm">Contato</p>
        <ul class="mt-4 space-y-4">
          {footerContacts.map((c) => {
            const href = contactHref(c);
            return (
              <li>
                <p class="text-xs text-white/45">{c.role}</p>
                {href ? (
                  <a href={href} target={c.type === "whatsapp" ? "_blank" : undefined} rel="noopener" class="text-sm text-lightgrey hover:text-white transition-colors">{c.value}</a>
                ) : (
                  <span class="text-sm text-lightgrey">{c.value}</span>
                )}
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Coluna 4: comece agora -->
      <div>
        <p class="font-display font-bold text-white text-sm">Comece agora</p>
        <p class="mt-4 text-sm text-paragraph">Tire suas dúvidas e configure sua ferramenta com a gente — passo a passo.</p>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary w-full mt-4">
          <Icon name="whatsapp" class="w-4 h-4" /> Falar no WhatsApp
        </a>
        <a href={`mailto:${company.email}`} class="btn btn-secondary w-full mt-3">
          <Icon name="mail" class="w-4 h-4" /> Enviar e-mail
        </a>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/40">© {year} {company.name} · {company.tagline}. Todos os direitos reservados.</p>
      <p class="text-xs text-white/40">{company.cnpjNote}</p>
    </div>
  </div>
</footer>

<!-- WhatsApp flutuante -->
<a
  href={wa}
  target="_blank"
  rel="noopener"
  class="fixed bottom-5 right-5 z-50 grid place-items-center w-14 h-14 rounded-full bg-green-500 text-white shadow-[0_10px_30px_-6px_rgba(34,197,94,.6)] hover:scale-105 transition-transform"
  aria-label="Falar no WhatsApp"
>
  <Icon name="whatsapp" class="w-7 h-7" />
</a>
