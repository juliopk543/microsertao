---
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import { whatsappUrl, company } from "../data/site";
const wa = whatsappUrl("Olá! Quero começar com a MicroSertão.");
---

<section id="app" class="bg-white py-16 md:py-20">
  <div class="container-x">
    <div class="relative overflow-hidden rounded-2xl bg-ink-900 bg-pattern px-8 py-12 md:px-16 md:py-16">
      <div class="absolute -right-10 -top-10 w-72 h-72 stripes opacity-10 rotate-12"></div>

      <div class="relative max-w-2xl">
        <Logo />
        <h2 class="mt-6 font-display font-bold text-white text-3xl sm:text-[40px] leading-tight tracking-tight text-balance">
          Tenha uma melhor experiência com a MicroSertão
        </h2>
        <p class="mt-4 text-lg text-white/70 max-w-xl">
          Tudo roda no navegador, sem instalar nada. A gente ajuda na configuração e no treinamento,
          passo a passo. Comece hoje mesmo.
        </p>

        <!-- Blocos de contato (no lugar das lojas de app) -->
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href={wa} target="_blank" rel="noopener" class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/12 hover:border-brand-500 px-5 py-3.5 transition-colors">
            <Icon name="whatsapp" class="w-7 h-7 text-brand-500" />
            <span class="text-left">
              <span class="block text-xs text-white/50">Fale agora</span>
              <span class="block text-sm font-semibold text-white">{company.whatsappLabel}</span>
            </span>
          </a>
          <a href={`mailto:${company.email}`} class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/12 hover:border-brand-500 px-5 py-3.5 transition-colors">
            <Icon name="mail" class="w-7 h-7 text-brand-500" />
            <span class="text-left">
              <span class="block text-xs text-white/50">Envie um e-mail</span>
              <span class="block text-sm font-semibold text-white">{company.email}</span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
