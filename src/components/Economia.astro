---
import Icon from "./Icon.astro";
import { pricing, features, whatsappUrl } from "../data/site";
const wa = whatsappUrl("Olá! Quero contratar o plano de R$400/ano da MicroSertão.");
---

<section id="economia" class="bg-white text-ink-900 py-20 md:py-28 overflow-hidden">
  <div class="container-x">
    <!-- Cabeçalho em duas colunas (igual ao #Indicacao do MRP) -->
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start">
      <div class="reveal">
        <p class="eyebrow mb-1">Economia de verdade</p>
        <h2 class="font-display font-bold text-ink-900 text-3xl sm:text-[42px] leading-tight tracking-tight text-balance">
          Sua gestão completa por até <span class="text-brand-500">75% menos</span>
        </h2>
      </div>
      <div class="reveal">
        <p class="text-paragraph text-lg">
          Enquanto as ferramentas comuns somam cerca de {pricing.common.yearly.replace("≈ ", "")} por ano,
          a MicroSertão custa uma anuidade única e transparente. Tudo num só lugar, sem mensalidade que pesa.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a href={wa} target="_blank" rel="noopener" class="btn btn-primary px-6 py-4">
            <Icon name="whatsapp" class="w-5 h-5" /> Contratar agora
          </a>
          <a href="#setores" class="btn btn-outline px-6 py-4">Ver os setores</a>
        </div>
      </div>
    </div>

    <!-- Painel comparativo grande (análogo ao dashboard do MRP) -->
    <div class="mt-12 grid lg:grid-cols-[1fr_1.4fr] gap-5 reveal">
      <!-- Comparação de preço -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-1 gap-5">
        <div class="rounded-2xl border border-ink-900/10 bg-cream-50 p-7">
          <p class="text-sm text-paragraph">{pricing.common.label}</p>
          <p class="mt-3 text-4xl font-display font-bold text-ink-900/40 line-through decoration-red-400/70">{pricing.common.yearly.replace("≈ ", "")}</p>
          <p class="mt-1 text-sm text-paragraph">{pricing.common.monthly}</p>
        </div>
        <div class="relative rounded-2xl border-2 border-brand-500 bg-cream-100 p-7">
          <span class="absolute -top-3 left-7 inline-flex items-center gap-1 rounded-full bg-brand-500 px-3 py-1 text-xs font-semibold text-white">
            <Icon name="bolt" class="w-3.5 h-3.5" /> Melhor escolha
          </span>
          <p class="text-sm font-semibold text-brand-600">{pricing.ours.label}</p>
          <p class="mt-3 text-5xl font-display font-extrabold text-ink-900">{pricing.ours.yearly}</p>
          <p class="mt-1 text-sm text-paragraph">{pricing.ours.note}</p>
        </div>
      </div>

      <!-- Tudo incluído (as 8 features) -->
      <div class="rounded-2xl border border-ink-900/10 bg-white p-7 shadow-sm">
        <p class="font-display font-bold text-ink-900">Tudo já vem incluído</p>
        <p class="text-sm text-paragraph">Do caixa ao agendamento, do estoque à equipe — num só painel.</p>
        <div class="mt-5 grid sm:grid-cols-2 gap-x-6 gap-y-4">
          {features.map((f) => (
            <div class="flex items-start gap-3">
              <span class="grid place-items-center w-9 h-9 shrink-0 rounded-lg bg-brand-500/12 text-brand-600">
                <Icon name={f.icon} class="w-5 h-5" />
              </span>
              <div>
                <p class="font-semibold text-ink-900 text-sm">{f.title}</p>
                <p class="text-xs text-paragraph leading-relaxed">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
