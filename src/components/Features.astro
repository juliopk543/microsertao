---
import Icon from "./Icon.astro";
import { features } from "../data/site";
---

<section id="recursos" class="py-20 md:py-28 bg-cream-100 text-ink-900">
  <div class="container-x">
    <div class="grid lg:grid-cols-2 gap-10 items-end">
      <div class="reveal">
        <span class="text-brand-600 font-semibold text-sm tracking-[0.12em] uppercase">Tudo em um só lugar</span>
        <h2 class="mt-3 font-display font-bold text-3xl sm:text-4xl tracking-tight text-balance">
          Cada aplicativo já vem completo.
        </h2>
      </div>
      <p class="text-ink-900/60 text-lg reveal">
        Do caixa ao agendamento, do estoque à equipe. Você gerencia o negócio inteiro de um só painel —
        no computador ou no celular.
      </p>
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-px rounded-3xl overflow-hidden border border-ink-900/10 bg-ink-900/10">
      {features.map((f) => (
        <div class="bg-cream-50 p-6 hover:bg-white transition-colors reveal">
          <span class="grid place-items-center w-11 h-11 rounded-xl bg-brand-500/12 text-brand-600">
            <Icon name={f.icon} class="w-6 h-6" />
          </span>
          <h3 class="mt-4 font-display font-semibold text-lg">{f.title}</h3>
          <p class="mt-1.5 text-sm text-ink-900/55 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
