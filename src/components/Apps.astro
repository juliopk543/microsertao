---
import Icon from "./Icon.astro";
import { apps } from "../data/site";
---

<section id="aplicativos" class="py-20 md:py-28 bg-ink-900 border-y border-white/5">
  <div class="container-x">
    <div class="max-w-2xl reveal">
      <span class="eyebrow">Aplicativos</span>
      <h2 class="mt-3 font-display font-bold text-white text-3xl sm:text-4xl tracking-tight text-balance">
        Um app sob medida para cada setor.
      </h2>
      <p class="mt-4 text-white/60 text-lg">
        Cada aplicativo do HUB é pensado para a rotina do seu negócio — com as ferramentas certas, sem excesso.
      </p>
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {apps.map((app) => (
        <div class="card p-6 group hover:-translate-y-1 hover:border-brand-500/40 transition-all duration-300 reveal">
          <span class="grid place-items-center w-12 h-12 rounded-2xl bg-brand-500/12 text-brand-400 group-hover:bg-brand-500 group-hover:text-white transition-colors">
            <Icon name={app.icon} class="w-6 h-6" />
          </span>
          <h3 class="mt-5 font-display font-semibold text-lg text-white">{app.name}</h3>
          <p class="mt-2 text-sm text-white/55 leading-relaxed">{app.desc}</p>
          <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-brand-400 opacity-0 group-hover:opacity-100 transition-opacity">
            Saiba mais <Icon name="arrow" class="w-4 h-4" />
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
