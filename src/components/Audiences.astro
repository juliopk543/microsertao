---
import Icon from "./Icon.astro";
import { audiences } from "../data/site";
const list = [audiences.empreendedor, audiences.prefeitura];
// monta a URL de um asset em /public respeitando o BASE_URL
const asset = (file: string) => `${import.meta.env.BASE_URL}/${file}`.replace(/\/+/g, "/");
---

<section id="publicos" class="relative pt-32 pb-20 md:pt-40 md:pb-28 bg-ink-950 transition-colors duration-500">
  <div class="container-x">
    <div class="max-w-2xl reveal">
      <span class="eyebrow">Para quem é</span>
      <h2 class="mt-3 font-display font-bold text-white text-3xl sm:text-4xl tracking-tight text-balance">
        Uma plataforma, dois mundos conectados.
      </h2>
      <p class="mt-4 text-white/60 text-lg">
        O empreendedor ganha gestão e economia. O município ganha um canal direto e inteligente com os cidadãos.
        Escolha o seu lado:
      </p>
    </div>

    <!-- Toggle -->
    <div class="mt-8 inline-flex p-1 rounded-2xl border border-white/10 bg-white/5 reveal" role="tablist" aria-label="Escolha o público">
      {list.map((a, i) => (
        <button
          class="aud-tab inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-semibold transition-colors text-white/60"
          data-tab={a.key}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
        >
          <Icon name={a.key === "empreendedor" ? "bag" : "megaphone"} class="w-4 h-4" />
          {a.label}
        </button>
      ))}
    </div>

    <!-- Panels -->
    <div class="mt-10">
      {list.map((a, i) => (
        <div class="aud-panel grid lg:grid-cols-2 gap-10 lg:gap-16 items-center" data-panel={a.key} hidden={i !== 0}>
          <div>
            <h3 class="font-display font-bold text-2xl sm:text-3xl text-white tracking-tight text-balance">{a.title}</h3>
            <p class="mt-4 text-white/60 text-lg">{a.description}</p>
            <a href={a.cta.href} class="btn btn-primary mt-7">
              {a.cta.label}
              <Icon name="arrow" class="w-4 h-4" />
            </a>
          </div>

          <div class="aud-cards grid sm:grid-cols-2 gap-4">
            {a.bullets.map((b) => (
              <Fragment>
                <!-- imagem fixa do app (intercalada, uma por card) — só aparece no stacking mobile -->
                <div class="stack-img sm:hidden">
                  <img src={asset(b.img)} alt="" aria-hidden="true" width="1800" height="768" loading="lazy" />
                </div>
                <div class="aud-card card p-5 hover:border-brand-500/40 transition-colors">
                  <span class="aud-ico grid place-items-center w-10 h-10 rounded-xl bg-brand-500/12 text-brand-400 transition-colors">
                    <Icon name="check" class="w-5 h-5" />
                  </span>
                  <h4 class="mt-3 font-semibold text-white">{b.title}</h4>
                  <p class="mt-1 text-sm text-white/55">{b.desc}</p>
                </div>
              </Fragment>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const section = document.getElementById("publicos");
  const tabs = document.querySelectorAll<HTMLButtonElement>(".aud-tab");
  const panels = document.querySelectorAll<HTMLElement>(".aud-panel");

  const activate = (key: string) => {
    const isPref = key === "prefeitura";
    // troca de paleta: azul/dourado para Prefeitura, escuro/laranja para Empreendedor
    section?.classList.toggle("theme-navy", isPref);

    tabs.forEach((t) => {
      const on = t.dataset.tab === key;
      t.setAttribute("aria-selected", String(on));
      // a aba ativa usa laranja (empreendedor) — no tema azul o CSS sobrescreve para dourado
      t.classList.toggle("bg-brand-500", on);
      t.classList.toggle("text-white", on);
      t.classList.toggle("text-white/60", !on);
    });
    panels.forEach((p) => {
      p.hidden = p.dataset.panel !== key;
    });
  };

  tabs.forEach((t) => t.addEventListener("click", () => activate(t.dataset.tab!)));
  // estado inicial
  activate("empreendedor");
</script>

<style is:global>
  /* Tema azul/dourado quando a aba Prefeitura está ativa (igual à seção de municípios) */
  #publicos.theme-navy { background-color: var(--color-navy-700); }
  #publicos.theme-navy .eyebrow { color: var(--color-sun-400); }
  #publicos.theme-navy .aud-tab[aria-selected="true"] {
    background-color: var(--color-sun-400);
    color: #0c2733;
  }
  #publicos.theme-navy .btn-primary {
    background-color: var(--color-sun-400);
    color: #0c2733;
    box-shadow: 0 10px 30px -10px rgba(244, 181, 63, .55);
  }
  #publicos.theme-navy .btn-primary:hover { background-color: #f0ad2e; }
  #publicos.theme-navy .aud-ico {
    background-color: rgba(244, 181, 63, .16);
    color: var(--color-sun-400);
  }
  #publicos.theme-navy .aud-card:hover { border-color: rgba(244, 181, 63, .4); }

  /* ===== Scroll stacking intercalado (imagem + card) — somente mobile ===== */
  @media (max-width: 639.98px) {
    /* desfaz o grid: coluna única empilhável (imagem, card, imagem, card...) */
    .aud-cards { display: block; }
    .aud-cards > * + * { margin-top: 1rem; }

    /* imagem fixa (print do app) acima de cada card */
    .aud-cards .stack-img {
      position: sticky;
      top: 5.5rem;            /* fixa logo abaixo do header fixo */
      overflow: hidden;
      background: var(--color-ink-950);
    }
    .aud-cards .stack-img img {
      display: block;
      width: 100%;
      height: 16rem;
      object-fit: cover;
      object-position: top;
    }
    /* gradiente escuro embaixo: esconde o que sobrar da imagem antes do próximo subir */
    .aud-cards .stack-img::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 55%, var(--color-ink-950) 100%);
      pointer-events: none;
    }

    /* cards: fixam e cobrem totalmente (fundo opaco) */
    .aud-cards .aud-card {
      position: sticky;
      top: 5.5rem;
      min-height: 12rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, .05), rgba(255, 255, 255, .02)),
        var(--color-ink-900);
      box-shadow: 0 -12px 30px -12px rgba(0, 0, 0, .65);
    }

    /* ===== Tema Prefeitura (navy): tudo precisa fundir com o azul, não com o preto ===== */
    /* imagem e gradiente de máscara desaparecem no navy (em vez de no ink) */
    #publicos.theme-navy .aud-cards .stack-img { background: var(--color-navy-700); }
    #publicos.theme-navy .aud-cards .stack-img::after {
      background: linear-gradient(to bottom, transparent 55%, var(--color-navy-700) 100%);
    }
    /* cards em painel navy (levemente mais claro que o fundo da seção) */
    #publicos.theme-navy .aud-cards .aud-card {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, .07), rgba(255, 255, 255, .025)),
        #15485e;
    }

    /* respeita quem prefere menos movimento: volta ao empilhamento normal */
    @media (prefers-reduced-motion: reduce) {
      .aud-cards .stack-img,
      .aud-cards .aud-card { position: static; box-shadow: none; }
      .aud-cards .aud-card { min-height: 0; }
    }
  }
</style>
