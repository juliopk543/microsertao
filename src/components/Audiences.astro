---
import Icon from "./Icon.astro";
import { audiences, whatsappUrl } from "../data/site";
const list = [audiences.empreendedor, audiences.prefeitura];
const waEmp = whatsappUrl("Olá! Quero a MicroSertão para o meu negócio.");
const waPref = whatsappUrl("Olá! Represento um município e quero conhecer a parceria pública.");
const ctas = {
  empreendedor: { label: "Quero para meu negócio", href: waEmp },
  prefeitura: { label: "Falar sobre parceria pública", href: waPref },
};
const bulletIcons = ["wallet", "calendar", "chart", "bolt", "megaphone", "users", "shield", "pin"];
---

<section id="publicos" class="bg-white text-ink-900 py-20 md:py-28 overflow-hidden">
  <div class="container-x grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Visual à esquerda (análogo ao lottie do MRP) -->
    <div class="relative reveal order-2 lg:order-1">
      <div class="absolute -left-6 top-10 -z-10 w-64 h-64 rounded-[2rem] bg-brand-500/15 rotate-6"></div>
      <div class="absolute right-8 -bottom-6 -z-10 w-40 h-40 stripes opacity-10 rotate-12"></div>
      <div class="mx-auto w-[280px] rounded-[2.2rem] border-[6px] border-ink-900 bg-ink-900 shadow-2xl overflow-hidden">
        <div class="bg-ink-850 px-5 pt-6 pb-5">
          <div class="flex items-center justify-between">
            <span class="text-xs text-white/50">Hoje</span>
            <span class="text-xs text-brand-400">8 agendamentos</span>
          </div>
          <p class="mt-3 text-2xl font-display font-bold text-white">R$ 1.240<span class="text-sm text-white/40">,00</span></p>
          <p class="text-xs text-white/40">recebido no dia</p>
          <div class="mt-4 space-y-2">
            {["Corte + Barba", "Manicure", "Lavagem", "Aula de Jiu-Jitsu"].map((t, i) => (
              <div class="flex items-center justify-between rounded-xl bg-white/5 px-3 py-2.5">
                <span class="text-sm text-white/80">{t}</span>
                <span class={`text-xs ${i === 0 ? "text-green-400" : "text-white/40"}`}>{i === 0 ? "pago" : "agendado"}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Conteúdo à direita -->
    <div class="reveal order-1 lg:order-2">
      <p class="eyebrow mb-1">Para empreendedores e prefeituras</p>
      <h2 class="font-display font-bold text-ink-900 text-3xl sm:text-[42px] leading-tight tracking-tight text-balance">
        Uma plataforma, dois mundos conectados
      </h2>
      <p class="mt-3 text-paragraph text-lg">Escolha o seu lado e veja as vantagens que viram resultado.</p>

      <!-- Abas (Empreendedor / Prefeitura) -->
      <div class="mt-7 inline-flex p-1 rounded-lg bg-cream-100 border border-ink-900/8" role="tablist">
        {list.map((a, i) => (
          <button
            class="aud-tab inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold transition-colors text-paragraph"
            data-tab={a.key}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
          >
            <Icon name={a.key === "empreendedor" ? "bag" : "megaphone"} class="w-4 h-4" />
            {a.label}
          </button>
        ))}
      </div>

      <!-- Painéis -->
      <div class="mt-8">
        {list.map((a, i) => (
          <div class="aud-panel" data-panel={a.key} hidden={i !== 0}>
            <div class="space-y-5">
              {a.bullets.map((b, bi) => (
                <div>
                  <div class="flex items-center gap-2.5">
                    <Icon name={bulletIcons[bi % bulletIcons.length]} class="w-7 h-7 text-brand-500 shrink-0" />
                    <span class="font-display font-bold text-ink-900">{b.title}</span>
                  </div>
                  <p class="mt-1 ml-[2.4rem] text-paragraph">{b.desc}</p>
                </div>
              ))}
            </div>

            <!-- Frame de CTA (igual à persona do MRP) -->
            <div class="mt-7 flex items-center justify-between gap-4 rounded-xl bg-cream-100 px-5 py-4">
              <span class="text-sm font-medium text-ink-900">{a.key === "empreendedor" ? "Quero organizar meu negócio!" : "Quero levar para minha cidade!"}</span>
              <a href={ctas[a.key].href} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-500 transition-colors whitespace-nowrap">
                {ctas[a.key].label} <Icon name="arrow" class="w-4 h-4" />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".aud-tab");
  const panels = document.querySelectorAll<HTMLElement>(".aud-panel");

  const activate = (key: string) => {
    tabs.forEach((t) => {
      const on = t.dataset.tab === key;
      t.setAttribute("aria-selected", String(on));
      t.classList.toggle("bg-white", on);
      t.classList.toggle("shadow-sm", on);
      t.classList.toggle("text-brand-600", on);
      t.classList.toggle("text-paragraph", !on);
    });
    panels.forEach((p) => {
      p.hidden = p.dataset.panel !== key;
    });
  };

  tabs.forEach((t) => t.addEventListener("click", () => activate(t.dataset.tab!)));
  activate("empreendedor");
</script>
