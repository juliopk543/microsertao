---
import Icon from "./Icon.astro";
import { audiences } from "../data/site";
const list = [audiences.empreendedor, audiences.prefeitura];
---

<section id="publicos" class="relative py-20 md:py-28 bg-ink-950">
  <div class="container-x">
    <div class="max-w-2xl reveal">
      <span class="eyebrow">Para quem é</span>
      <h2 class="mt-3 font-display font-bold text-white text-3xl sm:text-4xl tracking-tight text-balance">
        Uma plataforma, dois mundos conectados.
      </h2>
      <p class="mt-4 text-white/60 text-lg">
        O empreendedor ganha gestão e economia. O município ganha um canal direto e inteligente com os cidadãos.
        Escolha o seu lado:
      </p>
    </div>

    <!-- Toggle -->
    <div class="mt-8 inline-flex p-1 rounded-2xl border border-white/10 bg-white/5 reveal" role="tablist" aria-label="Escolha o público">
      {list.map((a, i) => (
        <button
          class="aud-tab inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-semibold transition-colors text-white/60"
          data-tab={a.key}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
        >
          <Icon name={a.key === "empreendedor" ? "bag" : "megaphone"} class="w-4 h-4" />
          {a.label}
        </button>
      ))}
    </div>

    <!-- Panels -->
    <div class="mt-10">
      {list.map((a, i) => (
        <div class="aud-panel grid lg:grid-cols-2 gap-10 lg:gap-16 items-center" data-panel={a.key} hidden={i !== 0}>
          <div>
            <h3 class="font-display font-bold text-2xl sm:text-3xl text-white tracking-tight text-balance">{a.title}</h3>
            <p class="mt-4 text-white/60 text-lg">{a.description}</p>
            <a href={a.cta.href} class="btn btn-primary mt-7">
              {a.cta.label}
              <Icon name="arrow" class="w-4 h-4" />
            </a>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            {a.bullets.map((b) => (
              <div class="card p-5 hover:border-brand-500/40 transition-colors">
                <span class="grid place-items-center w-10 h-10 rounded-xl bg-brand-500/12 text-brand-400">
                  <Icon name="check" class="w-5 h-5" />
                </span>
                <h4 class="mt-3 font-semibold text-white">{b.title}</h4>
                <p class="mt-1 text-sm text-white/55">{b.desc}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".aud-tab");
  const panels = document.querySelectorAll<HTMLElement>(".aud-panel");

  const activate = (key: string) => {
    tabs.forEach((t) => {
      const on = t.dataset.tab === key;
      t.setAttribute("aria-selected", String(on));
      t.classList.toggle("bg-brand-500", on);
      t.classList.toggle("text-white", on);
      t.classList.toggle("text-white/60", !on);
    });
    panels.forEach((p) => {
      p.hidden = p.dataset.panel !== key;
    });
  };

  tabs.forEach((t) => t.addEventListener("click", () => activate(t.dataset.tab!)));
  // estado inicial
  activate("empreendedor");
</script>
