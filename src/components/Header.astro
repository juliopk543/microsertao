---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { navLinks, whatsappUrl } from "../data/site";

const wa = whatsappUrl("Olá! Quero conhecer os aplicativos da MicroSertão.");
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">
  <div class="container-x">
    <nav class="mt-3 flex items-center justify-between rounded-2xl border border-white/10 bg-ink-900/70 backdrop-blur-xl px-4 py-2.5 transition-colors">
      <Logo />

      <ul class="hidden lg:flex items-center gap-1">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class="px-3 py-2 text-sm text-white/70 hover:text-white rounded-lg hover:bg-white/5 transition-colors"
            >{l.label}</a>
          </li>
        ))}
      </ul>

      <div class="hidden lg:flex items-center gap-2">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary">
          <Icon name="whatsapp" class="w-4 h-4" />
          Falar no WhatsApp
        </a>
      </div>

      <!-- Mobile toggle -->
      <button
        id="menu-toggle"
        class="lg:hidden grid place-items-center w-10 h-10 rounded-lg border border-white/10 text-white"
        aria-label="Abrir menu"
        aria-expanded="false"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="lg:hidden hidden mt-2 rounded-2xl border border-white/10 bg-ink-900/95 backdrop-blur-xl p-3">
      <ul class="flex flex-col">
        {navLinks.map((l) => (
          <li>
            <a href={l.href} class="block px-3 py-3 text-white/80 hover:text-white hover:bg-white/5 rounded-lg transition-colors" data-close>{l.label}</a>
          </li>
        ))}
      </ul>
      <a href={wa} target="_blank" rel="noopener" class="btn btn-primary w-full mt-2">
        <Icon name="whatsapp" class="w-4 h-4" />
        Falar no WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("shadow-lg", window.scrollY > 8);
    const nav = header.querySelector("nav");
    if (nav) nav.classList.toggle("bg-ink-900/90", window.scrollY > 8);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
  menu?.querySelectorAll("[data-close]").forEach((a) =>
    a.addEventListener("click", () => menu.classList.add("hidden")),
  );
</script>
