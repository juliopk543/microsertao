---
import Icon from "./Icon.astro";
import { apps, whatsappUrl } from "../data/site";
const wa = whatsappUrl("Olá! Meu setor não está na lista — quero saber se a MicroSertão atende.");
---

<section id="setores" class="bg-cream-50 text-ink-900 py-20 md:py-28 overflow-hidden">
  <div class="container-x grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Visual à esquerda -->
    <div class="relative reveal">
      <div class="absolute -left-6 top-8 -z-10 w-72 h-72 rounded-[2.5rem] bg-brand-500/15 -rotate-6"></div>
      <div class="rounded-3xl border border-ink-900/10 bg-white shadow-xl p-6">
        <div class="grid grid-cols-2 gap-4">
          {apps.map((app, i) => (
            <div class={`rounded-2xl p-5 ${i % 3 === 0 ? "bg-brand-500 text-white" : "bg-cream-100 text-ink-900"}`}>
              <Icon name={app.icon} class={`w-8 h-8 ${i % 3 === 0 ? "text-white" : "text-brand-500"}`} />
              <p class="mt-4 font-display font-semibold">{app.name}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Conteúdo à direita -->
    <div class="reveal">
      <p class="eyebrow mb-1">Aplicativos do HUB</p>
      <h2 class="font-display font-bold text-ink-900 text-3xl sm:text-[42px] leading-tight tracking-tight text-balance">
        Um app sob medida para cada setor
      </h2>
      <p class="mt-3 text-paragraph text-lg">
        Cada aplicativo é pensado para a rotina do seu negócio — com as ferramentas certas, sem excesso.
      </p>

      <!-- Cards de setores com status (igual aos "locais" do MRP) -->
      <div class="mt-7 space-y-3">
        {apps.map((app) => (
          <div class="flex items-center justify-between gap-4 rounded-xl border border-ink-900/10 bg-white px-4 py-3.5">
            <div class="flex items-center gap-3">
              <span class="grid place-items-center w-10 h-10 rounded-lg bg-brand-500/12 text-brand-600">
                <Icon name={app.icon} class="w-5 h-5" />
              </span>
              <div>
                <p class="font-display font-semibold text-ink-900">{app.name}</p>
                <p class="text-xs text-paragraph">{app.desc}</p>
              </div>
            </div>
            <span class="inline-flex items-center gap-1.5 shrink-0 text-sm font-medium text-[#4d933c]">
              <Icon name="check" class="w-4 h-4" /> {app.status}
            </span>
          </div>
        ))}

        <!-- Frame "seu setor não está aqui?" -->
        <div class="flex items-center justify-between gap-4 rounded-xl bg-cream-100 px-4 py-3.5">
          <span class="text-sm font-medium text-ink-900">Seu setor não está aqui?</span>
          <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-500 transition-colors whitespace-nowrap">
            <Icon name="whatsapp" class="w-4 h-4" /> Fale com a gente
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
