---
import Icon from "./Icon.astro";
import { prefeituraCards, whatsappUrl } from "../data/site";
const wa = whatsappUrl("Olá! Represento um município e quero conhecer a parceria pública da MicroSertão.");
---

<section id="prefeituras" class="bg-ink-900 bg-pattern py-20 md:py-28 overflow-hidden">
  <div class="container-x grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Título dividido (igual ao MVV do MRP) -->
    <div class="reveal">
      <p class="eyebrow mb-2">Para municípios</p>
      <h2 class="font-display font-bold text-3xl sm:text-[40px] leading-tight tracking-tight text-balance">
        <span class="text-white/45">Transparência, dados e</span>
        <span class="text-white"> economia pública para a sua cidade</span>
      </h2>
      <p class="mt-5 text-white/65 text-lg max-w-lg">
        Com os dados do comércio local, o município alcança o cidadão certo, na hora certa —
        sem depender de publicidade cara em plataformas estrangeiras.
      </p>
      <a href={wa} target="_blank" rel="noopener" class="btn btn-primary mt-8 px-6 py-4">
        Falar sobre parceria pública
        <Icon name="arrow" class="w-4 h-4" />
      </a>
    </div>

    <!-- 3 cards (igual aos mvvcards) -->
    <div class="space-y-4 reveal">
      {prefeituraCards.map((c) => (
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
          <div class="flex items-center gap-3">
            <span class="grid place-items-center w-10 h-10 rounded-lg bg-brand-500/15 text-brand-400">
              <Icon name="check" class="w-5 h-5" />
            </span>
            <h3 class="font-display font-bold text-white text-xl">{c.title}</h3>
          </div>
          <p class="mt-3 text-white/65">{c.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
