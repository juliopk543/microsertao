---
import Icon from "./Icon.astro";
import { pricing, whatsappUrl } from "../data/site";
const wa = whatsappUrl("Olá! Quero contratar o plano de R$400/ano da MicroSertão.");
const included = [
  "Financeiro completo",
  "Agendamento online 24h",
  "Loja e estoque",
  "Funcionários e comissões",
  "Relatórios e indicadores",
  "Suporte e treinamento",
];
---

<section id="preco" class="relative py-20 md:py-28 bg-ink-950 overflow-hidden">
  <div class="absolute -bottom-32 left-1/2 -translate-x-1/2 -z-10 w-[42rem] h-[42rem] rounded-full bg-brand-600/15 blur-[130px]"></div>

  <div class="container-x">
    <div class="max-w-2xl mx-auto text-center reveal">
      <span class="eyebrow">Preço justo</span>
      <h2 class="mt-3 font-display font-bold text-white text-3xl sm:text-4xl tracking-tight text-balance">
        Pague até <span class="text-brand-500">75% menos</span> pela ferramenta completa.
      </h2>
      <p class="mt-4 text-white/60 text-lg">
        Enquanto as ferramentas comuns somam cerca de R$ 1.600 por ano, a MicroSertão custa
        uma anuidade única e transparente.
      </p>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-5 max-w-4xl mx-auto items-stretch">
      <!-- Comum -->
      <div class="card p-8 reveal opacity-90">
        <p class="text-sm text-white/50">{pricing.common.label}</p>
        <p class="mt-4 text-4xl font-display font-bold text-white/70 line-through decoration-red-400/60">{pricing.common.yearly}</p>
        <p class="mt-1 text-sm text-white/40">{pricing.common.monthly}</p>
        <ul class="mt-6 space-y-3">
          {["Mensalidade que pesa", "Recursos espalhados em vários apps", "Custo cresce o ano todo"].map((t) => (
            <li class="flex items-center gap-3 text-sm text-white/45">
              <span class="grid place-items-center w-5 h-5 rounded-full bg-white/5 text-white/40">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
              </span>
              {t}
            </li>
          ))}
        </ul>
      </div>

      <!-- MicroSertão -->
      <div class="relative card p-8 border-brand-500/40 bg-gradient-to-b from-brand-500/10 to-transparent reveal">
        <span class="absolute -top-3 right-6 inline-flex items-center gap-1 rounded-full bg-brand-500 px-3 py-1 text-xs font-semibold text-white shadow-lg">
          <Icon name="bolt" class="w-3.5 h-3.5" /> Melhor escolha
        </span>
        <p class="text-sm text-brand-400 font-medium">{pricing.ours.label}</p>
        <p class="mt-4 text-5xl font-display font-extrabold text-white">{pricing.ours.yearly}</p>
        <p class="mt-1 text-sm text-white/50">{pricing.ours.note}</p>
        <ul class="mt-6 space-y-3">
          {included.map((t) => (
            <li class="flex items-center gap-3 text-sm text-white/80">
              <span class="grid place-items-center w-5 h-5 rounded-full bg-brand-500/20 text-brand-400">
                <Icon name="check" class="w-3.5 h-3.5" />
              </span>
              {t}
            </li>
          ))}
        </ul>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary w-full mt-8">
          <Icon name="whatsapp" class="w-5 h-5" />
          Contratar agora
        </a>
      </div>
    </div>
  </div>
</section>
