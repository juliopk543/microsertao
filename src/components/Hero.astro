---
import Icon from "./Icon.astro";
import { whatsappUrl } from "../data/site";
const wa = whatsappUrl("Olá! Quero conhecer os aplicativos da MicroSertão.");
const appImg = `${import.meta.env.BASE_URL}/app.png`.replace(/\/+/g, "/");
---

<section id="top" class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-28">
  <!-- background glow + grid -->
  <div class="absolute inset-0 -z-10 bg-grid opacity-60"></div>
  <div class="absolute -top-40 -left-32 -z-10 w-[40rem] h-[40rem] rounded-full bg-brand-600/20 blur-[120px]"></div>
  <div class="absolute -top-24 right-0 -z-10 w-[30rem] h-[30rem] rounded-full bg-teal-500/10 blur-[120px]"></div>
  <!-- diagonal stripes accent -->
  <div class="absolute top-1/3 right-[-6rem] -z-10 w-72 h-72 stripes opacity-[0.07] rotate-12 hidden md:block"></div>

  <div class="container-x grid lg:grid-cols-2 gap-12 items-center">
    <!-- Copy -->
    <div class="reveal">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/70">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
        HUB de aplicativos para microempreendedores
      </span>

      <h1 class="mt-5 font-display font-extrabold tracking-tight text-white text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-balance">
        Gestão completa sem mensalidade é
        <span class="text-brand-500">75% mais barato</span>.
      </h1>

      <p class="mt-5 text-lg text-white/65 max-w-xl text-balance">
        Aplicativos completos para <strong class="text-white/90">barbearias, manicures, lava-jatos e academias</strong>.
        Automatize agendamento, atendimento e financeiro — por uma fração do preço das ferramentas comuns.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary text-base px-6 py-3.5">
          <Icon name="whatsapp" class="w-5 h-5" />
          Começar agora
        </a>
        <a href="#aplicativos" class="btn btn-ghost text-base px-6 py-3.5">
          Ver aplicativos
          <Icon name="arrow" class="w-4 h-4" />
        </a>
      </div>

      <!-- mini stats (mobile) — no desktop flutuam ao redor da imagem -->
      <dl class="mt-10 grid grid-cols-3 gap-4 max-w-md lg:hidden">
        <div>
          <dt class="text-2xl font-display font-bold text-white">R$ 400<span class="text-base text-white/50">/ano</span></dt>
          <dd class="text-xs text-white/50 mt-1">Ferramenta completa</dd>
        </div>
        <div>
          <dt class="text-2xl font-display font-bold text-white">~75%</dt>
          <dd class="text-xs text-white/50 mt-1">de economia</dd>
        </div>
        <div>
          <dt class="text-2xl font-display font-bold text-white">24h</dt>
          <dd class="text-xs text-white/50 mt-1">Agenda automática</dd>
        </div>
      </dl>
    </div>

    <!-- Mockup: imagem real do app -->
    <div class="relative reveal flex justify-center">
      <!-- brilho laranja atrás do celular -->
      <div class="absolute inset-0 -z-10 m-auto w-72 h-72 rounded-full bg-brand-600/25 blur-[110px]"></div>

      <img
        src={appImg}
        alt="Aplicativo MicroSertão — painel de controle no celular"
        width="1080"
        height="1920"
        loading="eager"
        class="w-full max-w-[20rem] sm:max-w-sm drop-shadow-2xl select-none pointer-events-none"
      />

      <!-- Números flutuantes ao redor do app (desktop) -->
      <!-- R$ 400 / ano -->
      <div class="stat-pop absolute z-20 top-8 -left-6 xl:-left-10 hidden lg:block" style="--d:.05s">
        <div class="stat-float card bg-ink-850/95 backdrop-blur px-4 py-3 shadow-xl" style="--dur:4.6s;--fd:0s">
          <p class="text-2xl font-display font-bold text-white leading-none">
            <span class="stat-num" data-to="400" data-prefix="R$ ">R$ 0</span><span class="text-base text-white/50">/ano</span>
          </p>
          <p class="text-xs text-white/50 mt-1">Ferramenta completa</p>
        </div>
      </div>

      <!-- ~75% de economia -->
      <div class="stat-pop absolute z-20 top-1/3 -right-6 xl:-right-10 hidden lg:block" style="--d:.2s">
        <div class="stat-float card bg-ink-850/95 backdrop-blur px-4 py-3 shadow-xl" style="--dur:5.2s;--fd:.4s">
          <p class="text-2xl font-display font-bold text-brand-500 leading-none">
            <span class="stat-num" data-to="75" data-prefix="~" data-suffix="%">~0%</span>
          </p>
          <p class="text-xs text-white/50 mt-1">de economia</p>
        </div>
      </div>

      <!-- 24h agenda -->
      <div class="stat-pop absolute z-20 bottom-12 -left-2 xl:-left-6 hidden lg:block" style="--d:.35s">
        <div class="stat-float card bg-ink-850/95 backdrop-blur px-4 py-3 shadow-xl" style="--dur:4.9s;--fd:.8s">
          <p class="text-2xl font-display font-bold text-white leading-none">
            <span class="stat-num" data-to="24" data-suffix="h">0h</span>
          </p>
          <p class="text-xs text-white/50 mt-1">Agenda automática</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    function animateCount(el: HTMLElement) {
      const to = Number(el.dataset.to || "0");
      const prefix = el.dataset.prefix || "";
      const suffix = el.dataset.suffix || "";
      const dur = 1100;
      const start = performance.now();
      const step = (now: number) => {
        const p = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = prefix + Math.round(to * eased) + suffix;
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }

    const cards = document.querySelectorAll<HTMLElement>(".stat-pop");
    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const card = entry.target as HTMLElement;
          card.classList.add("is-visible");
          const num = card.querySelector<HTMLElement>(".stat-num");
          if (num && !num.dataset.done) {
            num.dataset.done = "1";
            setTimeout(() => animateCount(num), 250);
          }
          obs.unobserve(card);
        }
      },
      { threshold: 0.4 },
    );
    cards.forEach((c) => obs.observe(c));
  </script>
</section>
